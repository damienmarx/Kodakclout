{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@server/*": ["src/*"],
      "@kodakclout/shared": ["../shared/src/index.ts"],
      "@kodakclout/shared/*": ["../shared/src/*"]
    },
    "outDir": "./dist",
    "rootDirs": [".", "../shared"],
    
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
