# ─────────────────────────────────────────────────────────────────────────────
# Kodakclout – Server Environment Variables
# Copy this file to server/.env and fill in real values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# Server Configuration
PORT=8080
# IMPORTANT: set to "production" on your VPS so Express serves the React build
NODE_ENV=production
CLIENT_URL=https://cloutscape.org

# Database (MySQL / MariaDB)
DATABASE_URL=mysql://clout_user:clout_pass@127.0.0.1:3306/kodakclout

# Auth (JWT)
JWT_SECRET=your_super_secret_jwt_key_change_this
PASSWORD_SALT_ROUNDS=12

# Google OAuth (optional – leave blank if not using)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Game Provider – Clutch (340-game casino integration)
# Get your API key from your Clutch dashboard
CLUTCH_API_URL=https://api.clutch.io
CLUTCH_API_KEY=your_clutch_api_key

# Cloudflare Tunnel (optional – leave blank if not using)
# Get your API Token from Cloudflare Dashboard -> My Profile -> API Tokens
# The token needs permissions to Zone -> DNS -> Edit and Tunnel -> Read & Edit
CLOUDFLARE_API_TOKEN=
