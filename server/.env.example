
# ─────────────────────────────────────────────────────────────────────────────
# Kodakclout – Server Environment Variables
# Copy this file to server/.env and fill in real values before deploying.
# ─────────────────────────────────────────────────────────────────────────────

# Server Configuration
PORT=8080
NODE_ENV=production
CLIENT_URL=https://cloutscape.org
DOMAIN=cloutscape.org

# Database (MySQL / MariaDB)
DATABASE_URL=mysql://clout_user:clout_pass@localhost:3306/kodakclout

# Auth (JWT)
JWT_SECRET=your_super_secret_jwt_key_change_this
PASSWORD_SALT_ROUNDS=12

# Game Provider – Clutch (340-game casino integration)
CLUTCH_API_URL=http://localhost:8081
CLUTCH_API_KEY=your_clutch_api_key_change_this

# Cloudflare Tunnel (optional – leave blank if not using)
# CLOUDFLARE_API_TOKEN=
