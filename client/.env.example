# ─────────────────────────────────────────────────────────────────────────────
# Kodakclout – Client Environment Variables
# Copy this file to client/.env and fill in real values before deploying.
# In production the frontend is bundled and served by the Express server,
# so VITE_API_URL should be empty (same-origin) or set to your domain.
# ─────────────────────────────────────────────────────────────────────────────

# Production: leave empty so API calls go to the same origin (cloutscape.org)
# Development: set to http://localhost:8080 if running client/server separately
VITE_API_URL=

VITE_APP_NAME=Kodakclout
